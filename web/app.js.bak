        graphic: trend.hasData ? [] : {
            type: "text",
            left: "center",
            top: "middle",
            style: {
                text: "请选择网格查看趋势",
                fill: "rgba(102, 120, 136, 0.82)",
                fontSize: 13,
                fontWeight: 600
            }
